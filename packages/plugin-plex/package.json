{
  "name": "@mediachips/plugin-plex",
  "version": "0.1.0",
  "private": true,
  "description": "MediaChips Plex import plugin. Import library metadata from a Plex server.",
  "license": "GPL-3.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": "./src/components/*",
    "./server/*": "./src/server/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0"
  }
}
