{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["shared/*"],
      "@mediachips/plugin-adult": ["packages/plugin-adult/src/index.ts"],
      "@mediachips/plugin-adult/*": ["packages/plugin-adult/src/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.js",
    "shared/**/*.ts",
    "packages/plugin-adult/src/**/*.ts",
    "packages/plugin-adult/src/**/*.vue"
  ],
  "references": [{ "path": "./tsconfig.node.json" }],
  "exclude": []
}
